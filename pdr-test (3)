    let currentSection = null;
    let state = {
      answered: 0,
      correct: 0,
      wrong: 0
    };

    const sectionsView = document.getElementById("sectionsView");
    const quizView = document.getElementById("quizView");
    const sectionGrid = document.getElementById("sectionGrid");
    const questionsContainer = document.getElementById("questionsContainer");
    const quizSectionTitle = document.getElementById("quizSectionTitle");
    const quizSectionDesc = document.getElementById("quizSectionDesc");
    const progressFill = document.getElementById("progressFill");
    const resultCard = document.getElementById("resultCard");
    const resultText = document.getElementById("resultText");

    const backBtn = document.getElementById("backBtn");
    const retryBtn = document.getElementById("retryBtn");

    const sectionInfo = document.getElementById("sectionInfo");
    const answeredInfo = document.getElementById("answeredInfo");
    const correctInfo = document.getElementById("correctInfo");
    const wrongInfo = document.getElementById("wrongInfo");

    function renderSections() {
      sectionGrid.innerHTML = "";

      sections.forEach(section => {
        const card = document.createElement("div");
        card.className = "section-card";

        card.innerHTML = `
          <div class="section-number">Розділ ${section.number}</div>
          <h3 class="section-title">${section.title}</h3>
          <div class="section-meta">${section.description}</div>
          <button class="btn btn-primary">Почати тест</button>
        `;

        card.querySelector("button").addEventListener("click", () => startSection(section.id));
        sectionGrid.appendChild(card);
      });
    }

    function startSection(sectionId) {
      currentSection = structuredClone(sections.find(s => s.id === sectionId));
      state = { answered: 0, correct: 0, wrong: 0 };

      sectionsView.classList.add("hidden");
      quizView.classList.remove("hidden");
      backBtn.classList.remove("hidden");
      retryBtn.classList.remove("hidden");
      sectionInfo.classList.remove("hidden");
      answeredInfo.classList.remove("hidden");
      correctInfo.classList.remove("hidden");
      wrongInfo.classList.remove("hidden");
      resultCard.classList.add("hidden");

      quizSectionTitle.textContent = currentSection.title;
      quizSectionDesc.textContent = currentSection.description;
      sectionInfo.textContent = `Розділ: ${currentSection.title}`;

      renderQuestions();
      updateStats();
      updateProgress();
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function renderQuestions() {
      questionsContainer.innerHTML = "";

      currentSection.questions.forEach((q, index) => {
        const card = document.createElement("div");
        card.className = "question-card";
        card.id = `question-${index}`;

        const top = document.createElement("div");
        top.className = "question-top";
        top.textContent = `Питання ${index + 1}${q.sourceNumber ? ` · оригінал №${q.sourceNumber}` : ""}`;

        const title = document.createElement("p");
        title.className = "question-text";
        title.textContent = q.question;

        const options = document.createElement("div");
        options.className = "options";

        const letters = ["А", "Б", "В", "Г", "Д", "Е"];

        q.options.forEach((optionText, optionIndex) => {
          const btn = document.createElement("button");
          btn.className = "option-btn";
          btn.innerHTML = `
            <span class="option-letter">${letters[optionIndex] || optionIndex + 1}</span>
            <span>${optionText}</span>
          `;

          btn.addEventListener("click", () => answerQuestion(index, optionIndex));
          options.appendChild(btn);
        });

        const feedback = document.createElement("div");
        feedback.className = "feedback hidden";
        feedback.id = `feedback-${index}`;

        card.appendChild(top);
        card.appendChild(title);
        card.appendChild(options);
        card.appendChild(feedback);

        questionsContainer.appendChild(card);
      });
    }

    function answerQuestion(questionIndex, selectedIndex) {
      const question = currentSection.questions[questionIndex];

      if (question.answered) return;

      question.answered = true;
      question.selectedAnswer = selectedIndex;

      const card = document.getElementById(`question-${questionIndex}`);
      const buttons = card.querySelectorAll(".option-btn");
      const feedback = document.getElementById(`feedback-${questionIndex}`);

      buttons.forEach(btn => btn.disabled = true);

      const isCorrect = selectedIndex === question.correctAnswer;

      if (isCorrect) {
        buttons[selectedIndex].classList.add("correct");
        feedback.textContent = "Правильно";
        feedback.className = "feedback correct";
        state.correct++;
      } else {
        buttons[selectedIndex].classList.add("wrong");
        buttons[question.correctAnswer].classList.add("correct");
        feedback.textContent = "Неправильно";
        feedback.className = "feedback wrong";
        state.wrong++;
      }

      state.answered++;
      updateStats();
      updateProgress();

      if (state.answered === currentSection.questions.length) {
        showResult();
      }
    }

    function updateStats() {
      const total = currentSection ? currentSection.questions.length : 0;
      answeredInfo.textContent = `Пройдено: ${state.answered} / ${total}`;
      correctInfo.textContent = `Правильно: ${state.correct}`;
      wrongInfo.textContent = `Неправильно: ${state.wrong}`;
    }

    function updateProgress() {
      const total = currentSection ? currentSection.questions.length : 0;
      const percent = total ? (state.answered / total) * 100 : 0;
      progressFill.style.width = `${percent}%`;
    }

    function showResult() {
      const total = currentSection.questions.length;
      const percent = Math.round((state.correct / total) * 100);

      let label = "Добре";
      if (percent >= 90) label = "Відмінно";
      else if (percent < 60) label = "Потрібно ще потренуватись";

      resultText.textContent = `${label}. Ви відповіли правильно на ${state.correct} з ${total} питань (${percent}%).`;
      resultCard.classList.remove("hidden");
      resultCard.scrollIntoView({ behavior: "smooth", block: "center" });
    }

    function backToSections() {
      currentSection = null;
      state = { answered: 0, correct: 0, wrong: 0 };

      sectionsView.classList.remove("hidden");
      quizView.classList.add("hidden");
      backBtn.classList.add("hidden");
      retryBtn.classList.add("hidden");
      sectionInfo.classList.add("hidden");
      answeredInfo.classList.add("hidden");
      correctInfo.classList.add("hidden");
      wrongInfo.classList.add("hidden");
    }

    function retrySection() {
      if (!currentSection) return;
      startSection(currentSection.id);
    }

    backBtn.addEventListener("click", backToSections);
    retryBtn.addEventListener("click", retrySection);

    renderSections();
  </script>
